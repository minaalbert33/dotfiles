{
    "layer": "bottom", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 25, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 20  , // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces", 
        "wlr/mode", 
        "sway/scratchpad",
        "custom/media"
    ],
    "modules-center": [
        "clock",
        "hyprland/language"
    ],

    "modules-right": [ 
        "custom/media",       
        "tray", 
        "mpd", 
        "pulseaudio",
        "network",
        "cpu" , 
        "memory",
        "temperature",
        "backlight",
        "battery",
        "battery#bat2"],


    // Modules configuration
    // "sway/workspaces": {
    //     "disable-scroll": true,
    //     "all-outputs": true,
    //     "warp-on-scroll": false,
    //     "format": "{name}: {icon}",
    //     "format-icons": {
    //         "1": "яДа",
    //         "2": "яЙи",
    //         "3": "яДб",
    //         "4": "яЖ╝",
    //         "5": "яБ╡",
    //         "urgent": "яБк",
    //         "focused": "яЖТ",
    //         "default": "яДС"
    //     }
    // },
     // "hyprland/window": {
